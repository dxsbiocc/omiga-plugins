#!/usr/bin/env Rscript
# Template: heatmap/clustered
# Purpose: Clustered heatmap from a wide numeric matrix.
#
# Input example:
#   See example.tsv.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template heatmap/clustered
#
# Personalization:
#   This Rscript template emits plot-script.R and rerun.sh by default.
#   For one-off customization, edit the emitted source artifact and rerun/render it.
#   To save a reusable style, use scripts/promote_visual_template.py.

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") {
  if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
}
parse_formats <- function(value) {
  value <- arg_or(value, "png,pdf")
}
input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))

parse_bool <- function(x) tolower(as.character(x)) %in% c("1", "true", "t", "yes", "y")
config <- list(columns = list(feature = arg_or(3, "feature")), labels = list(title = arg_or(4, "Clustered heatmap")), transform = list(scale_rows = parse_bool(arg_or(5, "true"))), style = list(base_size = 12))
delimiter <- arg_or(6, "auto"); width <- as.numeric(arg_or(7, "7")); height <- as.numeric(arg_or(8, "5")); dpi <- as.integer(arg_or(9, "300"))
prepare_data <- function(df, config) {
  validate_columns(df, config$columns$feature, "heatmap/clustered input")
  sample_cols <- setdiff(colnames(df), config$columns$feature)
  df <- ensure_numeric_columns(df, sample_cols, "heatmap/clustered input")
  mat <- as.matrix(df[, sample_cols, drop = FALSE]); rownames(mat) <- df[[config$columns$feature]]
  if (isTRUE(config$transform$scale_rows)) { mat <- t(scale(t(mat))); mat[!is.finite(mat)] <- 0 }
  if (nrow(mat) > 1) mat <- mat[stats::hclust(stats::dist(mat))$order, , drop = FALSE]
  if (ncol(mat) > 1) mat <- mat[, stats::hclust(stats::dist(t(mat)))$order, drop = FALSE]
  data.frame(feature = rep(rownames(mat), times = ncol(mat)), sample = rep(colnames(mat), each = nrow(mat)), value = as.vector(mat), stringsAsFactors = FALSE)
}
make_plot <- function(df, config) { ggplot2::ggplot(df, ggplot2::aes(x = sample, y = feature, fill = value)) + ggplot2::geom_tile(color = "white", linewidth = 0.2) + ggplot2::scale_fill_gradient2(low = "#2563EB", mid = "white", high = "#DC2626") + ggplot2::labs(title = config$labels$title, x = "Sample", y = "Feature", fill = ifelse(config$transform$scale_rows, "z-score", "value")) + theme_visualization(base_size = config$style$base_size) }
customize_plot <- function(p, df, config) { p }

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  p <- make_plot(plot_df, config)
  p <- customize_plot(p, plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(data.frame(metric = c("template", "rows"), value = c("heatmap/clustered", nrow(plot_df))), file.path(outdir, "summary.tsv"))
  write_outputs_json(outdir, list(template = "heatmap/clustered", rows = nrow(plot_df)))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}

main()
