#!/usr/bin/env Rscript
# Template: scatter/ma
# Purpose: MA plot for differential-result tables.
#
# Input example:
#   See example.tsv.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template scatter/ma
#
# Personalization:
#   Edit the emitted source when customization is needed.
#   To save a reusable style, use scripts/promote_visual_template.py.

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))

config <- list(
  columns = list(mean = arg_or(3, "baseMean"), log2fc = arg_or(4, "log2FoldChange"), pvalue = arg_or(5, "padj"), label = arg_or(6, "gene")),
  thresholds = list(log2fc = as.numeric(arg_or(7, "1")), pvalue = as.numeric(arg_or(8, "0.05"))),
  labels = list(title = arg_or(9, "MA plot")),
  style = list(up = "#DC2626", down = "#2563EB", ns = "#9CA3AF", base_size = 12)
)
delimiter <- arg_or(10, "auto"); width <- as.numeric(arg_or(11, "7.5")); height <- as.numeric(arg_or(12, "5")); dpi <- as.integer(arg_or(13, "300"))

prepare_data <- function(df, config) {
  validate_columns(df, c(config$columns$mean, config$columns$log2fc, config$columns$pvalue, config$columns$label), "scatter/ma input")
  df <- ensure_numeric_columns(df, c(config$columns$mean, config$columns$log2fc, config$columns$pvalue), "scatter/ma input")
  df$.mean <- pmax(df[[config$columns$mean]], .Machine$double.xmin)
  df$.log2fc <- df[[config$columns$log2fc]]
  df$.pvalue <- pmax(df[[config$columns$pvalue]], .Machine$double.xmin)
  df$.status <- ifelse(df$.log2fc >= config$thresholds$log2fc & df$.pvalue <= config$thresholds$pvalue, "Up", ifelse(df$.log2fc <= -config$thresholds$log2fc & df$.pvalue <= config$thresholds$pvalue, "Down", "NS"))
  df$.status <- factor(df$.status, levels = c("Down", "NS", "Up"))
  df
}

make_plot <- function(df, config) {
  label_df <- utils::head(df[df$.status != "NS", ][order(df[df$.status != "NS", ]$.pvalue, -abs(df[df$.status != "NS", ]$.log2fc)), , drop = FALSE], 8)
  ggplot2::ggplot(df, ggplot2::aes(x = .mean, y = .log2fc, color = .status)) +
    ggplot2::geom_point(alpha = 0.78, size = 2.1) +
    ggplot2::geom_hline(yintercept = 0, linewidth = 0.35) +
    ggplot2::geom_hline(yintercept = c(-config$thresholds$log2fc, config$thresholds$log2fc), linetype = "dashed", linewidth = 0.35) +
    ggplot2::geom_text(data = label_df, ggplot2::aes(label = .data[[config$columns$label]]), vjust = -0.7, size = 3, show.legend = FALSE) +
    ggplot2::scale_x_log10() +
    ggplot2::scale_color_manual(values = c(Down = config$style$down, NS = config$style$ns, Up = config$style$up)) +
    ggplot2::labs(title = config$labels$title, x = config$columns$mean, y = "log2 fold change", color = "Status") +
    theme_visualization(base_size = config$style$base_size)
}

customize_plot <- function(p, df, config) p

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  p <- customize_plot(make_plot(plot_df, config), plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(data.frame(metric = c("template", "rows", "significant"), value = c("scatter/ma", nrow(plot_df), sum(plot_df$.status != "NS"))), file.path(outdir, "summary.tsv"))
  write_outputs_json(outdir, list(template = "scatter/ma", rows = nrow(plot_df), significant = sum(plot_df$.status != "NS")))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}

main()
