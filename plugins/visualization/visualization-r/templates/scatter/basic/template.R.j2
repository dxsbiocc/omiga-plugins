#!/usr/bin/env Rscript
# Template: scatter/basic
# Purpose: Basic grouped scatter plot for tabular data.
#
# Input example:
#   See example.tsv.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template scatter/basic
#
# Personalization:
#   This Rscript template emits plot-script.R and rerun.sh by default.
#   For one-off customization, edit the emitted source artifact and rerun/render it.
#   To save a reusable style, use scripts/promote_visual_template.py.

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") {
  if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
}
parse_formats <- function(value) {
  value <- arg_or(value, "png,pdf")
}
input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))

config <- list(
  columns = list(x = arg_or(3, "x_value"), y = arg_or(4, "y_value"), group = arg_or(5, "group"), label = arg_or(6, "label")),
  labels = list(title = arg_or(7, "Basic scatter plot"), x = arg_or(3, "x_value"), y = arg_or(4, "y_value")),
  style = list(point_size = 2.4, point_alpha = 0.82, label_size = 3.0, base_size = 12)
)
delimiter <- arg_or(8, "auto")
width <- as.numeric(arg_or(9, "7")); height <- as.numeric(arg_or(10, "5")); dpi <- as.integer(arg_or(11, "300"))

prepare_data <- function(df, config) {
  validate_columns(df, c(config$columns$x, config$columns$y), "scatter/basic input")
  df <- ensure_numeric_columns(df, c(config$columns$x, config$columns$y), "scatter/basic input")
  df
}

make_plot <- function(df, config) {
  group_col <- resolve_optional_column(df, config$columns$group)
  label_col <- resolve_optional_column(df, config$columns$label)
  mapping <- ggplot2::aes(x = .data[[config$columns$x]], y = .data[[config$columns$y]])
  if (!is.null(group_col)) mapping <- ggplot2::aes(x = .data[[config$columns$x]], y = .data[[config$columns$y]], color = .data[[group_col]])
  p <- ggplot2::ggplot(df, mapping) +
    ggplot2::geom_point(size = config$style$point_size, alpha = config$style$point_alpha) +
    ggplot2::labs(title = config$labels$title, x = config$labels$x, y = config$labels$y, color = group_col) +
    theme_visualization(base_size = config$style$base_size)
  if (!is.null(label_col)) {
    label_df <- utils::head(df[order(df[[config$columns$y]], decreasing = TRUE), , drop = FALSE], 3)
    p <- p + ggplot2::geom_text(data = label_df, ggplot2::aes(label = .data[[label_col]]), vjust = -0.7, size = config$style$label_size, show.legend = FALSE)
  }
  p
}

customize_plot <- function(p, df, config) {
  p
}

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  p <- make_plot(plot_df, config)
  p <- customize_plot(p, plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(data.frame(metric = c("template", "rows"), value = c("scatter/basic", nrow(plot_df))), file.path(outdir, "summary.tsv"))
  write_outputs_json(outdir, list(template = "scatter/basic", rows = nrow(plot_df)))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}

main()
