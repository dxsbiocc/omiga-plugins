{
  "name": "retrieval-dataset-gtex",
  "version": "0.1.0",
  "description": "Runs GTEx Portal search/query/fetch through Omiga local subprocess routing.",
  "retrieval": {
    "protocolVersion": 1,
    "runtime": {
      "command": "./scripts/retrieval_dataset_gtex.py",
      "args": [],
      "env": {
        "OMIGA_RETRIEVAL_SOURCE_IDS": "gtex",
        "OMIGA_RETRIEVAL_PLUGIN_NAME": "retrieval-dataset-gtex"
      },
      "cwd": ".",
      "idleTtlMs": 60000,
      "requestTimeoutMs": 30000,
      "cancelGraceMs": 750,
      "concurrency": 1
    },
    "resources": [
      {
        "id": "gtex",
        "category": "dataset",
        "label": "GTEx",
        "description": "Human gene and tissue-expression metadata via GTEx Portal API v2.",
        "aliases": [
          "genotype_tissue_expression",
          "tissue_expression"
        ],
        "subcategories": [
          "expression"
        ],
        "capabilities": [
          "search",
          "query",
          "fetch"
        ],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only GTEx Portal API."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "gencodeVersion",
            "type": "string",
            "description": "GTEx GENCODE version, default v26."
          },
          {
            "name": "genomeBuild",
            "type": "string",
            "description": "GTEx genome build, default GRCh38/hg38."
          }
        ]
      }
    ]
  },
  "interface": {
    "displayName": "GTEx Retrieval Resource",
    "shortDescription": "GTEx tissue-expression metadata as a local retrieval plugin",
    "longDescription": "Runs GTEx Portal search/query/fetch through Omiga local subprocess routing.",
    "developerName": "Omiga",
    "category": "Retrieval",
    "capabilities": [
      "Dataset",
      "Retrieval",
      "Local Subprocess",
      "Search",
      "Query",
      "Fetch"
    ],
    "brandColor": "#DB2777",
    "defaultPrompt": [
      "Query GTEx expression metadata for BRCA1.",
      "Fetch GTEx tissue information through the GTEx plugin."
    ]
  }
}
