        "OMIGA_RETRIEVAL_SOURCE_IDS": "ena,ena_run,ena_experiment,ena_sample,ena_analysis,ena_assembly,ena_sequence,arrayexpress,ensembl",
        "OMIGA_RETRIEVAL_PLUGIN_NAME": "resource-embl-ebi"
      },
      "cwd": ".",
      "idleTtlMs": 60000,
      "requestTimeoutMs": 30000,
      "cancelGraceMs": 750,
      "concurrency": 1
    },
