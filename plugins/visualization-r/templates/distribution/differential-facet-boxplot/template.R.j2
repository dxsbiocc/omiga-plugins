#!/usr/bin/env Rscript
# Template: distribution/differential-facet-boxplot
# Purpose: Faceted differential boxplot with jittered points and per-facet
#          significance labels.
#
# Migration note:
#   This template migrates OmicsAgent backend/scripts/visual/boxplot/differential_facet
#   from the private JSON ggplot2 DSL into direct, editable R/ggplot2 code.
#   The source data.json is bundled as example.tsv.
#
# Input example:
#   See example.tsv with gene/exprs/group columns.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template distribution/differential-facet-boxplot

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") {
  if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
}
parse_number_arg <- function(index, default) {
  value <- suppressWarnings(as.numeric(arg_or(index, as.character(default))))
  if (is.na(value)) default else value
}
parse_integer_arg <- function(index, default) {
  value <- suppressWarnings(as.integer(arg_or(index, as.character(default))))
  if (is.na(value)) default else value
}
parse_logical_arg <- function(index, default) {
  raw <- tolower(arg_or(index, if (default) "true" else "false"))
  if (raw %in% c("true", "t", "1", "yes", "y")) return(TRUE)
  if (raw %in% c("false", "f", "0", "no", "n")) return(FALSE)
  default
}
parse_csv_arg <- function(index, default) {
  raw <- arg_or(index, default)
  if (!nzchar(raw) || tolower(raw) == "auto") return(character())
  values <- trimws(strsplit(raw, ",", fixed = TRUE)[[1]])
  values[nzchar(values)]
}

input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))
config <- list(
  columns = list(
    facet = arg_or(3, "gene"),
    group = arg_or(4, "group"),
    value = arg_or(5, "exprs")
  ),
  labels = list(
    title = arg_or(6, ""),
    x = arg_or(7, ""),
    y = arg_or(8, "Gene expression level")
  ),
  facet_order = parse_csv_arg(9, "auto"),
  group_order = parse_csv_arg(10, "Normal,Tumor"),
  style = list(
    palette = parse_csv_arg(11, "#8F499C,#4185BE,#6DC067,#F6DB35,#F78822"),
    box_width = parse_number_arg(12, 0.62),
    point_size = parse_number_arg(13, 2.0),
    point_alpha = parse_number_arg(14, 0.60),
    jitter_width = parse_number_arg(15, 0.15),
    strip_fill = arg_or(16, "#6dc067"),
    bracket_text_size = parse_number_arg(17, 3.5),
    base_size = parse_number_arg(18, 11)
  ),
  show_points = parse_logical_arg(19, TRUE),
  significance = list(
    enabled = parse_logical_arg(20, TRUE),
    alpha = parse_number_arg(21, 0.05),
    test = arg_or(22, "wilcox.test")
  ),
  random_seed = parse_integer_arg(23, 7)
)
delimiter <- arg_or(24, "auto")
width <- parse_number_arg(25, 6)
height <- parse_number_arg(26, 5)
dpi <- parse_integer_arg(27, 300)

if (!config$significance$test %in% c("wilcox.test", "t.test")) {
  stop("test must be one of: wilcox.test, t.test", call. = FALSE)
}

format_signif <- function(p) {
  if (is.na(p)) return("ns")
  if (p <= 0.0001) return("****")
  if (p <= 0.001) return("***")
  if (p <= 0.01) return("**")
  if (p <= 0.05) return("*")
  "ns"
}

prepare_data <- function(df, config) {
  validate_columns(df, c(config$columns$facet, config$columns$group, config$columns$value), "distribution/differential-facet-boxplot input")
  df <- ensure_numeric_columns(df, config$columns$value, "distribution/differential-facet-boxplot input")
  df$.facet_raw <- as.character(df[[config$columns$facet]])
  df$.group_raw <- as.character(df[[config$columns$group]])
  df$.value <- df[[config$columns$value]]
  df <- df[is.finite(df$.value) & nzchar(df$.facet_raw) & nzchar(df$.group_raw), , drop = FALSE]

  facets <- unique(df$.facet_raw)
  if (length(config$facet_order) > 0) {
    ordered_facets <- config$facet_order[config$facet_order %in% facets]
    facets <- c(ordered_facets, setdiff(facets, ordered_facets))
  }
  groups <- unique(df$.group_raw)
  if (length(config$group_order) > 0) {
    ordered_groups <- config$group_order[config$group_order %in% groups]
    groups <- c(ordered_groups, setdiff(groups, ordered_groups))
  }
  if (length(facets) < 1 || length(groups) < 2) {
    stop("distribution/differential-facet-boxplot requires at least one facet and at least two groups.", call. = FALSE)
  }
  df$.facet <- factor(df$.facet_raw, levels = facets)
  df$.group <- factor(df$.group_raw, levels = groups)
  df <- df[!is.na(df$.facet) & !is.na(df$.group), , drop = FALSE]
  set.seed(config$random_seed)
  df$.x <- as.numeric(df$.group)
  df$.x_point <- df$.x + stats::runif(nrow(df), -config$style$jitter_width / 2, config$style$jitter_width / 2)
  df
}

safe_pairwise_p <- function(x, y, test) {
  result <- try({
    if (identical(test, "t.test")) stats::t.test(x, y) else stats::wilcox.test(x, y, exact = FALSE)
  }, silent = TRUE)
  if (inherits(result, "try-error") || is.null(result$p.value)) return(NA_real_)
  as.numeric(result$p.value)
}

significance_data <- function(df, config) {
  if (!isTRUE(config$significance$enabled)) return(data.frame())
  groups <- levels(df$.group)
  if (length(groups) < 2) return(data.frame())
  rows <- lapply(levels(df$.facet), function(facet) {
    facet_df <- df[df$.facet == facet, , drop = FALSE]
    x <- facet_df$.value[facet_df$.group == groups[[1]]]
    y <- facet_df$.value[facet_df$.group == groups[[2]]]
    p <- safe_pairwise_p(x, y, config$significance$test)
    if (is.na(p) || p > config$significance$alpha) return(NULL)
    y_range <- diff(range(facet_df$.value, na.rm = TRUE))
    if (!is.finite(y_range) || y_range == 0) y_range <- 1
    data.frame(
      .facet = facet,
      x = (1 + length(groups)) / 2,
      y = max(facet_df$.value, na.rm = TRUE) + y_range * 0.10,
      label = format_signif(p),
      p = p,
      stringsAsFactors = FALSE
    )
  })
  rows <- Filter(Negate(is.null), rows)
  if (length(rows) == 0) return(data.frame())
  out <- do.call(rbind, rows)
  out$.facet <- factor(out$.facet, levels = levels(df$.facet))
  out
}

plot_theme <- function(config) {
  ggplot2::theme_bw(base_size = config$style$base_size) +
    ggplot2::theme(
      plot.background = ggplot2::element_rect(fill = "white", color = NA),
      panel.background = ggplot2::element_rect(fill = "white", color = NA),
      panel.grid = ggplot2::element_blank(),
      axis.text = ggplot2::element_text(face = "bold", size = 8),
      axis.title.y = ggplot2::element_text(size = 10, face = "bold"),
      axis.title.x = ggplot2::element_text(size = 10, face = "bold"),
      strip.text = ggplot2::element_text(face = "bold"),
      strip.background = ggplot2::element_rect(fill = config$style$strip_fill, color = "grey70"),
      plot.title = ggplot2::element_text(hjust = 0.5, face = "bold"),
      legend.position = "none"
    )
}

make_plot <- function(df, config) {
  groups <- levels(df$.group)
  palette <- config$style$palette
  if (length(palette) < length(groups)) palette <- rep(palette, length.out = length(groups))
  palette <- stats::setNames(palette[seq_along(groups)], groups)
  sig_df <- significance_data(df, config)

  p <- ggplot2::ggplot(df, ggplot2::aes(x = .x, y = .value)) +
    ggplot2::geom_boxplot(
      ggplot2::aes(group = .group, color = .group),
      width = config$style$box_width,
      outlier.shape = NA,
      fill = NA,
      linewidth = 0.65,
      show.legend = FALSE
    )

  if (isTRUE(config$show_points)) {
    p <- p + ggplot2::geom_point(
      ggplot2::aes(x = .x_point, y = .value, color = .group),
      inherit.aes = FALSE,
      size = config$style$point_size,
      alpha = config$style$point_alpha,
      show.legend = FALSE
    )
  }

  p <- p +
    ggplot2::scale_color_manual(values = palette, guide = "none") +
    ggplot2::scale_x_continuous(breaks = seq_along(groups), labels = groups, expand = ggplot2::expansion(add = 0.35)) +
    ggplot2::scale_y_continuous(expand = ggplot2::expansion(mult = c(0.06, 0.16))) +
    ggplot2::facet_wrap(stats::as.formula("~ .facet"), nrow = 1, scales = "free_x") +
    ggplot2::labs(title = config$labels$title, x = config$labels$x, y = config$labels$y) +
    plot_theme(config)

  if (nrow(sig_df) > 0) {
    p <- p + ggplot2::geom_text(
      data = sig_df,
      ggplot2::aes(x = x, y = y, label = label),
      inherit.aes = FALSE,
      size = config$style$bracket_text_size,
      fontface = "bold",
      show.legend = FALSE
    )
  }
  p
}
customize_plot <- function(p, df, config) { p }

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  sig_df <- significance_data(plot_df, config)
  p <- customize_plot(make_plot(plot_df, config), plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(
    data.frame(
      metric = c("template", "rows", "facets", "groups", "significant_facets", "test"),
      value = c("distribution/differential-facet-boxplot", nrow(plot_df), length(levels(plot_df$.facet)), paste(levels(plot_df$.group), collapse = ","), nrow(sig_df), config$significance$test)
    ),
    file.path(outdir, "summary.tsv")
  )
  write_outputs_json(outdir, list(template = "distribution/differential-facet-boxplot", rows = nrow(plot_df), facets = levels(plot_df$.facet), groups = levels(plot_df$.group), significant_facets = nrow(sig_df), test = config$significance$test))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}
main()
