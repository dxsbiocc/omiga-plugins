#!/usr/bin/env Rscript
# Template: bar/grouped
# Purpose: Grouped bar plot.
#
# Input example:
#   See example.tsv.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template bar/grouped
#
# Personalization:
#   This Rscript template emits plot-script.R and rerun.sh by default.
#   For one-off customization, edit the emitted source artifact and rerun/render it.
#   To save a reusable style, use scripts/promote_visual_template.py.

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") {
  if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
}
parse_formats <- function(value) {
  value <- arg_or(value, "png,pdf")
}
input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))

config <- list(columns = list(category = arg_or(3, "category"), value = arg_or(4, "value"), group = arg_or(5, "group"), se = arg_or(6, "se")), labels = list(title = arg_or(7, "Grouped bar plot")), style = list(base_size = 12))
delimiter <- arg_or(8, "auto"); width <- as.numeric(arg_or(9, "7")); height <- as.numeric(arg_or(10, "5")); dpi <- as.integer(arg_or(11, "300"))
prepare_data <- function(df, config) { validate_columns(df, c(config$columns$category, config$columns$value, config$columns$group), "bar/grouped input"); ensure_numeric_columns(df, c(config$columns$value, resolve_optional_column(df, config$columns$se)), "bar/grouped input") }
make_plot <- function(df, config) { p <- ggplot2::ggplot(df, ggplot2::aes(x = .data[[config$columns$category]], y = .data[[config$columns$value]], fill = .data[[config$columns$group]])) + ggplot2::geom_col(position = ggplot2::position_dodge(width = 0.75), width = 0.68); se_col <- resolve_optional_column(df, config$columns$se); if (!is.null(se_col)) p <- p + ggplot2::geom_errorbar(ggplot2::aes(ymin = .data[[config$columns$value]] - .data[[se_col]], ymax = .data[[config$columns$value]] + .data[[se_col]]), position = ggplot2::position_dodge(width = 0.75), width = 0.2); p + ggplot2::labs(title = config$labels$title, x = config$columns$category, y = config$columns$value, fill = config$columns$group) + theme_visualization(base_size = config$style$base_size) }
customize_plot <- function(p, df, config) { p }

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  p <- make_plot(plot_df, config)
  p <- customize_plot(p, plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(data.frame(metric = c("template", "rows"), value = c("bar/grouped", nrow(plot_df))), file.path(outdir, "summary.tsv"))
  write_outputs_json(outdir, list(template = "bar/grouped", rows = nrow(plot_df)))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}

main()
