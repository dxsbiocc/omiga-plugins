#!/usr/bin/env Rscript
# Template: scatter/embedding
# Purpose: UMAP/t-SNE style embedding scatter plot with optional group coloring and labels.
#
# Input example:
#   See example.tsv.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template scatter/embedding

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") { if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default }
input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))
config <- list(
  columns = list(x = arg_or(3, "umap_1"), y = arg_or(4, "umap_2"), group = arg_or(5, "cluster"), label = arg_or(6, "label")),
  labels = list(title = arg_or(7, "Embedding scatter plot")),
  style = list(point_size = 2.4, point_alpha = 0.82, label_size = 3, base_size = 12)
)
delimiter <- arg_or(8, "auto"); width <- as.numeric(arg_or(9, "6.5")); height <- as.numeric(arg_or(10, "5.8")); dpi <- as.integer(arg_or(11, "300"))

prepare_data <- function(df, config) {
  validate_columns(df, c(config$columns$x, config$columns$y), "scatter/embedding input")
  ensure_numeric_columns(df, c(config$columns$x, config$columns$y), "scatter/embedding input")
}

make_plot <- function(df, config) {
  group_col <- resolve_optional_column(df, config$columns$group)
  label_col <- resolve_optional_column(df, config$columns$label)
  mapping <- ggplot2::aes(x = .data[[config$columns$x]], y = .data[[config$columns$y]])
  if (!is.null(group_col)) mapping <- ggplot2::aes(x = .data[[config$columns$x]], y = .data[[config$columns$y]], color = .data[[group_col]])
  p <- ggplot2::ggplot(df, mapping) +
    ggplot2::geom_point(size = config$style$point_size, alpha = config$style$point_alpha) +
    ggplot2::coord_equal() +
    ggplot2::labs(title = config$labels$title, x = config$columns$x, y = config$columns$y, color = group_col) +
    theme_visualization(base_size = config$style$base_size)
  if (!is.null(group_col)) p <- p + ggplot2::scale_colour_manual(values = visualization_palette(length(unique(df[[group_col]]))))
  if (!is.null(label_col)) {
    label_df <- df[nzchar(as.character(df[[label_col]])), , drop = FALSE]
    p <- p + ggplot2::geom_text(data = label_df, ggplot2::aes(label = .data[[label_col]]), vjust = -0.75, size = config$style$label_size, check_overlap = TRUE, show.legend = FALSE)
  }
  p
}
customize_plot <- function(p, df, config) { p }

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  p <- customize_plot(make_plot(plot_df, config), plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(data.frame(metric = c("template", "rows"), value = c("scatter/embedding", nrow(plot_df))), file.path(outdir, "summary.tsv"))
  write_outputs_json(outdir, list(template = "scatter/embedding", rows = nrow(plot_df)))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s
", outdir))
}
main()
