#!/usr/bin/env Rscript
# Template: scatter/bezier
# Purpose: Paired-sample scatter with Bezier-style curved links.
#
# Migration note:
#   This template migrates OmicsAgent scatter/bezier from the private JSON
#   ggplot2 DSL into direct, editable R/ggplot2 code. The original data.json
#   has been converted to example.tsv. To avoid carrying a project-specific
#   JSON runtime or extra plotting dependency, the Bezier-like links are drawn
#   with ggplot2::geom_curve.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template scatter/bezier

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") {
  if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
}
parse_number_arg <- function(index, default) {
  value <- suppressWarnings(as.numeric(arg_or(index, as.character(default))))
  if (is.na(value)) default else value
}
parse_integer_arg <- function(index, default) {
  value <- suppressWarnings(as.integer(arg_or(index, as.character(default))))
  if (is.na(value)) default else value
}
parse_logical_arg <- function(index, default) {
  raw <- tolower(arg_or(index, if (default) "true" else "false"))
  if (raw %in% c("true", "t", "1", "yes", "y")) return(TRUE)
  if (raw %in% c("false", "f", "0", "no", "n")) return(FALSE)
  default
}
parse_csv_arg <- function(index, default = "") {
  raw <- arg_or(index, default)
  if (!nzchar(raw) || tolower(raw) == "auto") return(character())
  values <- trimws(strsplit(raw, ",", fixed = TRUE)[[1]])
  values[nzchar(values)]
}

input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))
config <- list(
  columns = list(
    group = arg_or(3, "sample_type"),
    value = arg_or(4, "BRCA1"),
    pair = arg_or(5, "patient")
  ),
  labels = list(
    title = arg_or(6, "TCGA-ACC"),
    x = arg_or(7, ""),
    y = arg_or(8, "Expression of BRCA1")
  ),
  group_order = parse_csv_arg(9, "Normal,Tumor"),
  style = list(
    palette = parse_csv_arg(10, "#2dde98,#ff4f81"),
    point_size = parse_number_arg(11, 3),
    point_alpha = parse_number_arg(12, 0.9),
    point_spread = parse_number_arg(13, 0.16),
    line_alpha = parse_number_arg(14, 0.5),
    line_width = parse_number_arg(15, 0.35),
    curve = parse_number_arg(16, 0.22),
    bracket_text_size = parse_number_arg(17, 3.2),
    base_size = parse_number_arg(18, 12)
  ),
  show_lines = parse_logical_arg(19, TRUE),
  significance = list(
    enabled = parse_logical_arg(20, TRUE),
    alpha = parse_number_arg(21, 0.05),
    max_brackets = parse_integer_arg(22, 3),
    test = arg_or(23, "wilcox.test")
  )
)
delimiter <- arg_or(24, "auto")
width <- parse_number_arg(25, 4.2)
height <- parse_number_arg(26, 5.6)
dpi <- parse_integer_arg(27, 300)

if (!config$significance$test %in% c("wilcox.test", "t.test")) {
  stop("test must be one of: wilcox.test, t.test", call. = FALSE)
}

first_seen <- function(x) unique(as.character(x))

spread_sequence <- function(n, width) {
  if (n <= 1 || width <= 0) return(rep(0, n))
  raw <- seq_len(n) - (n + 1) / 2
  raw / max(abs(raw)) * width
}

format_p_value <- function(p) {
  if (is.na(p)) return("p = NA")
  if (p < 0.001) return("p < 0.001")
  sprintf("p = %.2g", p)
}

prepare_data <- function(df, config) {
  validate_columns(df, c(config$columns$group, config$columns$value, config$columns$pair), "scatter/bezier input")
  df <- ensure_numeric_columns(df, config$columns$value, "scatter/bezier input")
  df$.group_raw <- as.character(df[[config$columns$group]])
  df$.pair <- as.character(df[[config$columns$pair]])
  df$.value <- df[[config$columns$value]]
  df <- df[is.finite(df$.value) & nzchar(df$.group_raw) & nzchar(df$.pair), , drop = FALSE]
  groups <- first_seen(df$.group_raw)
  if (length(config$group_order) > 0) {
    ordered <- config$group_order[config$group_order %in% groups]
    groups <- c(ordered, setdiff(groups, ordered))
  }
  if (length(groups) < 2) {
    stop("scatter/bezier requires at least two groups.", call. = FALSE)
  }
  df <- df[df$.group_raw %in% groups, , drop = FALSE]
  df$.group <- factor(df$.group_raw, levels = groups)
  pair_levels <- first_seen(df$.pair)
  pair_offsets <- stats::setNames(spread_sequence(length(pair_levels), config$style$point_spread), pair_levels)
  df$.pair_index <- match(df$.pair, pair_levels)
  df$.x <- as.numeric(df$.group) + pair_offsets[df$.pair]
  df
}

paired_curve_data <- function(df) {
  if (nrow(df) == 0) return(data.frame())
  rows <- list()
  for (pair in unique(df$.pair)) {
    pair_df <- df[df$.pair == pair, c(".pair", ".group", ".x", ".value"), drop = FALSE]
    pair_df <- pair_df[order(as.numeric(pair_df$.group)), , drop = FALSE]
    pair_df <- pair_df[!duplicated(pair_df$.group), , drop = FALSE]
    if (nrow(pair_df) < 2) next
    for (i in seq_len(nrow(pair_df) - 1)) {
      rows[[length(rows) + 1]] <- data.frame(
        .pair = pair,
        x = pair_df$.x[[i]],
        xend = pair_df$.x[[i + 1]],
        y = pair_df$.value[[i]],
        yend = pair_df$.value[[i + 1]],
        stringsAsFactors = FALSE
      )
    }
  }
  if (length(rows) == 0) return(data.frame())
  do.call(rbind, rows)
}

safe_paired_p <- function(df, group1, group2, config) {
  left <- df[df$.group == group1, c(".pair", ".value"), drop = FALSE]
  right <- df[df$.group == group2, c(".pair", ".value"), drop = FALSE]
  colnames(left) <- c(".pair", "x")
  colnames(right) <- c(".pair", "y")
  merged <- merge(left, right, by = ".pair", all = FALSE, sort = FALSE)
  if (nrow(merged) < 2) return(NA_real_)
  result <- try({
    if (identical(config$significance$test, "t.test")) {
      stats::t.test(merged$x, merged$y, paired = TRUE)
    } else {
      stats::wilcox.test(merged$x, merged$y, paired = TRUE, exact = FALSE)
    }
  }, silent = TRUE)
  if (inherits(result, "try-error") || is.null(result$p.value)) return(NA_real_)
  as.numeric(result$p.value)
}

significance_data <- function(df, config) {
  if (!isTRUE(config$significance$enabled)) return(data.frame())
  groups <- levels(df$.group)
  if (length(groups) < 2) return(data.frame())
  pairs <- utils::combn(groups, 2, simplify = FALSE)
  rows <- lapply(pairs, function(pair) {
    p <- safe_paired_p(df, pair[[1]], pair[[2]], config)
    data.frame(group1 = pair[[1]], group2 = pair[[2]], p = p, stringsAsFactors = FALSE)
  })
  out <- do.call(rbind, rows)
  out <- out[!is.na(out$p) & out$p < config$significance$alpha, , drop = FALSE]
  if (nrow(out) == 0) return(data.frame())
  out <- utils::head(out[order(out$p), , drop = FALSE], config$significance$max_brackets)
  y_range <- diff(range(df$.value, na.rm = TRUE))
  if (!is.finite(y_range) || y_range == 0) y_range <- 1
  y_max <- max(df$.value, na.rm = TRUE)
  out$x <- match(out$group1, groups)
  out$xend <- match(out$group2, groups)
  out$y <- y_max + y_range * (0.08 + seq_len(nrow(out)) * 0.07)
  out$tip_y <- out$y - y_range * 0.025
  out$label <- vapply(out$p, format_p_value, character(1))
  out
}

plot_theme <- function(config) {
  base <- if (requireNamespace("ggprism", quietly = TRUE)) {
    ggprism::theme_prism(base_size = config$style$base_size)
  } else {
    theme_visualization(base_size = config$style$base_size)
  }
  base + ggplot2::theme(
    plot.background = ggplot2::element_rect(fill = "white", color = NA),
    panel.background = ggplot2::element_rect(fill = "white", color = NA),
    panel.grid.major.x = ggplot2::element_blank(),
    panel.grid.minor = ggplot2::element_blank(),
    plot.title = ggplot2::element_text(size = 14, hjust = 0.5, face = "bold"),
    legend.position = "none"
  )
}

make_plot <- function(df, config) {
  groups <- levels(df$.group)
  palette <- config$style$palette
  if (length(palette) < length(groups)) palette <- rep(palette, length.out = length(groups))
  palette <- stats::setNames(palette[seq_along(groups)], groups)
  curve_df <- paired_curve_data(df)
  sig_df <- significance_data(df, config)

  p <- ggplot2::ggplot(df, ggplot2::aes(x = .x, y = .value))
  if (isTRUE(config$show_lines) && nrow(curve_df) > 0) {
    p <- p + ggplot2::geom_curve(
      data = curve_df,
      ggplot2::aes(x = x, xend = xend, y = y, yend = yend),
      inherit.aes = FALSE,
      curvature = config$style$curve,
      linewidth = config$style$line_width,
      alpha = config$style$line_alpha,
      color = "#caccd1"
    )
  }

  p <- p +
    ggplot2::geom_point(
      ggplot2::aes(x = .x, y = .value),
      inherit.aes = FALSE,
      size = config$style$point_size + 1,
      color = "white",
      alpha = 0.95,
      show.legend = FALSE
    ) +
    ggplot2::geom_point(
      ggplot2::aes(x = .x, y = .value, fill = .group),
      inherit.aes = FALSE,
      shape = 21,
      stroke = 0.5,
      size = config$style$point_size,
      color = "#111827",
      alpha = config$style$point_alpha,
      show.legend = FALSE
    ) +
    ggplot2::scale_fill_manual(values = palette, guide = "none") +
    ggplot2::scale_x_continuous(breaks = seq_along(groups), labels = groups, expand = ggplot2::expansion(add = 0.35)) +
    ggplot2::scale_y_continuous(expand = ggplot2::expansion(mult = c(0.08, 0.20))) +
    ggplot2::labs(title = config$labels$title, x = config$labels$x, y = config$labels$y) +
    plot_theme(config)

  if (nrow(sig_df) > 0) {
    p <- p +
      ggplot2::geom_segment(data = sig_df, ggplot2::aes(x = x, xend = xend, y = y, yend = y), inherit.aes = FALSE, linewidth = 0.45) +
      ggplot2::geom_segment(data = sig_df, ggplot2::aes(x = x, xend = x, y = tip_y, yend = y), inherit.aes = FALSE, linewidth = 0.45) +
      ggplot2::geom_segment(data = sig_df, ggplot2::aes(x = xend, xend = xend, y = tip_y, yend = y), inherit.aes = FALSE, linewidth = 0.45) +
      ggplot2::geom_text(data = sig_df, ggplot2::aes(x = (x + xend) / 2, y = y, label = label), inherit.aes = FALSE, vjust = -0.25, size = config$style$bracket_text_size)
  }
  p
}

customize_plot <- function(p, df, config) { p }

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  p <- customize_plot(make_plot(plot_df, config), plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(
    data.frame(
      metric = c("template", "rows", "pairs", "groups", "test"),
      value = c("scatter/bezier", nrow(plot_df), length(unique(plot_df$.pair)), length(levels(plot_df$.group)), config$significance$test)
    ),
    file.path(outdir, "summary.tsv")
  )
  write_outputs_json(outdir, list(template = "scatter/bezier", rows = nrow(plot_df), pairs = length(unique(plot_df$.pair)), groups = length(levels(plot_df$.group)), test = config$significance$test))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}
main()
