#!/usr/bin/env Rscript
# Template: scatter/correlation
# Purpose: Correlation scatter with fit line and correlation annotation.
#
# Input example:
#   See example.tsv.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template scatter/correlation
#
# Personalization:
#   This Rscript template emits plot-script.R and rerun.sh by default.
#   For one-off customization, edit the emitted source artifact and rerun/render it.
#   To save a reusable style, use scripts/promote_visual_template.py.

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") {
  if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
}
parse_formats <- function(value) {
  value <- arg_or(value, "png,pdf")
}
input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))

config <- list(columns = list(x = arg_or(3, "expression_a"), y = arg_or(4, "expression_b"), group = arg_or(5, "group"), label = arg_or(6, "feature")), labels = list(title = arg_or(7, "Correlation scatter")), style = list(point_size = 2.4, point_alpha = 0.82, base_size = 12))
delimiter <- arg_or(8, "auto"); width <- as.numeric(arg_or(9, "7")); height <- as.numeric(arg_or(10, "5")); dpi <- as.integer(arg_or(11, "300"))
prepare_data <- function(df, config) { validate_columns(df, c(config$columns$x, config$columns$y), "scatter/correlation input"); ensure_numeric_columns(df, c(config$columns$x, config$columns$y), "scatter/correlation input") }
make_plot <- function(df, config) {
  group_col <- resolve_optional_column(df, config$columns$group)
  r <- suppressWarnings(stats::cor(df[[config$columns$x]], df[[config$columns$y]], use = "complete.obs"))
  subtitle <- if (is.finite(r)) sprintf("Pearson r = %.3f", r) else "Pearson r unavailable"
  mapping <- ggplot2::aes(x = .data[[config$columns$x]], y = .data[[config$columns$y]])
  if (!is.null(group_col)) mapping <- ggplot2::aes(x = .data[[config$columns$x]], y = .data[[config$columns$y]], color = .data[[group_col]])
  ggplot2::ggplot(df, mapping) + ggplot2::geom_point(size = config$style$point_size, alpha = config$style$point_alpha) + ggplot2::geom_smooth(method = "lm", se = FALSE, color = "#111827", linewidth = 0.6) + ggplot2::labs(title = config$labels$title, subtitle = subtitle, x = config$columns$x, y = config$columns$y, color = group_col) + theme_visualization(base_size = config$style$base_size)
}
customize_plot <- function(p, df, config) { p }

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  plot_df <- prepare_data(df, config)
  p <- make_plot(plot_df, config)
  p <- customize_plot(p, plot_df, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(data.frame(metric = c("template", "rows"), value = c("scatter/correlation", nrow(plot_df))), file.path(outdir, "summary.tsv"))
  write_outputs_json(outdir, list(template = "scatter/correlation", rows = nrow(plot_df)))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}

main()
